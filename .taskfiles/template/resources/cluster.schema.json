{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cluster Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_cidr",
    "cluster_api_addr",
    "cluster_dns_gateway_addr",
    "cluster_gateway_addr",
    "repository_name",
    "cloudflare_domain",
    "cloudflare_token",
    "cloudflare_gateway_addr"
  ],
  "properties": {
    "node_cidr": {
      "type": "string",
      "description": "Network CIDR for the nodes (e.g. 192.168.1.0/24)"
    },
    "node_dns_servers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "node_ntp_servers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "node_default_gateway": {
      "type": "string"
    },
    "node_vlan_tag": {
      "type": "string"
    },
    "cluster_pod_cidr": {
      "type": "string",
      "default": "10.42.0.0/16"
    },
    "cluster_svc_cidr": {
      "type": "string",
      "default": "10.43.0.0/16"
    },
    "cluster_api_addr": {
      "type": "string",
      "description": "Load balancer IP for the Kube API"
    },
    "cluster_api_tls_sans": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cluster_dns_gateway_addr": {
      "type": "string",
      "description": "Load balancer IP for k8s-gateway (split DNS)"
    },
    "cluster_gateway_addr": {
      "type": "string",
      "description": "Load balancer IP for the internal gateway"
    },
    "repository_name": {
      "type": "string",
      "description": "GitHub repository (e.g. owner/repo)"
    },
    "repository_branch": {
      "type": "string"
    },
    "repository_visibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    },
    "cloudflare_domain": {
      "type": "string",
      "description": "Domain managed in Cloudflare"
    },
    "cloudflare_token": {
      "type": "string"
    },
    "cloudflare_gateway_addr": {
      "type": "string",
      "description": "Load balancer IP for the external/Cloudflare gateway"
    },
    "cilium_loadbalancer_mode": {
      "type": "string",
      "enum": [
        "dsr",
        "snat"
      ]
    },
    "cilium_bgp_router_addr": {
      "type": "string"
    },
    "cilium_bgp_router_asn": {
      "type": "string"
    },
    "cilium_bgp_node_asn": {
      "type": "string"
    },
    "nas_server": {
      "type": "string",
      "description": "NAS NFS server IP address"
    },
    "nas_path": {
      "type": "string",
      "description": "NAS NFS export path (root path shared via NFS)"
    },
    "nas_coding_path": {
      "type": "string",
      "description": "NAS NFS path for the shared coding workspace"
    },
    "claude_instances": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Claude Code instance names"
    },
    "ttyd_credential": {
      "type": "string",
      "description": "Shared ttyd web terminal credential (user:password)"
    },
    "extras": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "postgres_password": {
      "type": "string"
    },
    "trello_api_key": {
      "type": "string"
    },
    "trello_api_token": {
      "type": "string"
    },
    "trello_board_id": {
      "type": "string"
    },
    "line_channel_access_token": {
      "type": "string"
    },
    "line_channel_secret": {
      "type": "string"
    },
    "line_notify_group_id": {
      "type": "string"
    },
    "anthropic_api_key": {
      "type": "string"
    },
    "database_url": {
      "type": "string"
    },
    "cloudflare_tunnel_token": {
      "type": "string"
    },
    "github_webhook_token": {
      "type": "string"
    }
  }
}